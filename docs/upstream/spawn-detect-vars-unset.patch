diff --git a/tests/test_spawn.bats b/tests/test_spawn.bats
index bf1eab2..69ae101 100644
--- a/tests/test_spawn.bats
+++ b/tests/test_spawn.bats
@@ -161,6 +161,33 @@ teardown() {
   [[ "$output" == *"$PROJ"* ]]
 }
 
+@test "spawn: boot script unsets the target type's detect= vars (#session-collision)" {
+  # tmux new-window/split-window and every OS-terminal launch path copy the
+  # parent shell's exported environment into the child verbatim. If a
+  # claude-code session spawns another claude-code peer (actas from inside
+  # claude-code, e.g. a reviewer<->implementer pair), the child would inherit
+  # the parent's own CLAUDE_CODE_SESSION_ID/CLAUDECODE and the child CLI can
+  # mistake the parent's session for its own (observed: persistent
+  # "Authentication error" in the child on every turn). type.conf's `detect=`
+  # already names exactly these vars, so the boot script must unset them
+  # before the CLI line runs.
+  bash "$SCRIPTS/join.sh" myteam existing claude-code "$PROJ"
+  run bash "$SCRIPTS/spawn.sh" claude-code alice --project "$PROJ" --no-wait
+  [ "$status" -eq 0 ]
+  boot="$(cat "$CAPTURE")"
+  run cat "$boot"
+  [[ "$output" == *"unset CLAUDE_CODE_SESSION_ID"* ]]
+}
+
+@test "spawn: boot script has no unset line for a type with detect=explicit" {
+  bash "$SCRIPTS/join.sh" myteam existing claude-code "$PROJ"
+  run bash "$SCRIPTS/spawn.sh" copilot alice --project "$PROJ" --no-wait
+  [ "$status" -eq 0 ]
+  boot="$(cat "$CAPTURE")"
+  run cat "$boot"
+  [[ "$output" != *"unset "* ]]
+}
